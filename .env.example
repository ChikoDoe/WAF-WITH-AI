# ─── Sentinel WAF Configuration ──────────────────────────────────────────────

# Server
PORT=3001

# ─── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare ───────────────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Token needs: Zone:Firewall Services:Edit, Zone:Zone:Read
CF_API_TOKEN=your_cloudflare_api_token_here

# Get from: https://dash.cloudflare.com → Your Zone → Overview → Zone ID
CF_ZONE_ID=your_zone_id_here

# Get from: https://dash.cloudflare.com/profile → Account ID
CF_ACCOUNT_ID=your_account_id_here

# ─── Nginx Log Paths ──────────────────────────────────────────────────────────
# Comma-separated, supports multiple log files
NGINX_ACCESS_LOG=/var/log/nginx/access.log
NGINX_ERROR_LOG=/var/log/nginx/error.log

# ─── Firewall ─────────────────────────────────────────────────────────────────
# IPs that will NEVER be blocked (comma-separated)
# Add your own IP, monitoring servers, etc.
ALLOWED_IPS=1.2.3.4,5.6.7.8

# ─── Security ────────────────────────────────────────────────────────────────
# Basic auth for dashboard (optional, use with nginx reverse proxy)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme_use_strong_password
